{
  "manifest_version": 3,
  "name": "Ketuvia: accessible captions",
  "version": "2.0.8",
  "description": "Replaces YouTube's word-by-word auto-captions with customizable phrase-based captions for better readability and accessibility.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://m.youtube.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html",
    "default_title": "Ketuvia"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": ["inject.js"],
      "css": ["overlay.css"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*",
        "fonts/*/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
