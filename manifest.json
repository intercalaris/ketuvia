{
  "manifest_version": 3,
  "name": "Ketuvia: accessible captions",
  "version": "1.8.5",
  "description": "Replaces YouTube's word-by-word auto-captions with phrase-based captions for better readability and accessibility.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://m.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ketuvia"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": ["inject.js"],
      "css": ["overlay.css"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*",
        "fonts/Atkinson_Hyperlegible/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
